<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">
<title>BI Portfólio de Expansão</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
font-family: Arial;
background:#f4f6fb;
margin:0;
padding:40px;
}

h1{
margin-bottom:30px;
}

.cards{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:40px;
}

.card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 3px 15px rgba(0,0,0,0.08);
text-align:center;
}

.card h3{
margin:0;
color:#777;
font-size:14px;
}

.card h2{
margin-top:10px;
font-size:32px;
}

.graficos{
display:grid;
grid-template-columns:1fr 1fr;
gap:40px;
}

canvas{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 3px 15px rgba(0,0,0,0.08);
}

</style>

</head>

<body>

<h1>Dashboard Portfólio de Expansão</h1>

<div class="cards">

<div class="card">
<h3>Total Projetos</h3>
<h2 id="total">0</h2>
</div>

<div class="card">
<h3>Em andamento</h3>
<h2 id="andamento">0</h2>
</div>

<div class="card">
<h3>Concluídos</h3>
<h2 id="concluido">0</h2>
</div>

<div class="card">
<h3>Progresso Médio</h3>
<h2 id="progresso">0%</h2>
</div>

</div>

<div class="graficos">

<canvas id="statusChart"></canvas>

<canvas id="progressoChart"></canvas>

</div>

<script>

const url = "https://docs.google.com/spreadsheets/d/1l9Rrc3xwxaZvzIu-g-y7_5z6CTdDgAYV-VZFIF3Lte4/export?format=csv";

fetch(url)
.then(res => res.text())
.then(data => {

const linhas = data.split("\n").slice(1);

let total = 0;
let andamento = 0;
let concluido = 0;

let progressoTotal = 0;

let nomes = [];
let progressos = [];

linhas.forEach(l => {

const col = l.split(",");

const projeto = col[0];
const status = col[2];
const progresso = parseFloat(col[3]);

if(!projeto) return;

total++;

nomes.push(projeto);
progressos.push(progresso);

if(status=="Em andamento") andamento++;
if(status=="Concluído") concluido++;

if(!isNaN(progresso)) progressoTotal += progresso;

});

const progressoMedio = Math.round(progressoTotal/total);

document.getElementById("total").innerText = total;
document.getElementById("andamento").innerText = andamento;
document.getElementById("concluido").innerText = concluido;
document.getElementById("progresso").innerText = progressoMedio + "%";

new Chart(document.getElementById("statusChart"),{
type:"doughnut",
data:{
labels:["Em andamento","Concluído"],
datasets:[{
data:[andamento,concluido]
}]
}
});

new Chart(document.getElementById("progressoChart"),{
type:"bar",
data:{
labels:nomes,
datasets:[{
label:"Progresso %",
data:progressos
}]
}
});

});

</script>

</body>

</html>
